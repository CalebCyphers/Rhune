# Rhunebot environment
# Copy to .env and fill in values.

# Discord bot token
BOT_TOKEN=

# Discord application (client) id
CLIENT_ID=

# Presence status: online|idle|dnd|invisible
BOT_STATUS=online

# Optional: if set, commands will be deployed to a single dev guild for faster iteration.
# If unset, commands are deployed globally.
# GUILD_ID=

# PocketBase (source of truth)
PB_URL=https://the-crucible-database.fly.dev/
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=
